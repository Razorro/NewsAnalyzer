{
    "theme_id": "financial_market",
    "theme_name": "全球金融市场走势分析",
    "version": "1.0",
    "description": "专注于全球股市、债市、外汇、大宗商品走势分析，包含宏观经济和央行政策",
    
    "files": {
        "keywords": "keywords.json",
        "analysis_prompt": "analysis.txt",
        "trend_prompt": "trend.txt",
        "report_template": "report.html"
    },
    
    "data_extraction": {
        "extract_stock_indices": true,
        "extract_bond_yields": true,
        "extract_forex": true,
        "extract_commodities": true,
        "extract_central_bank": true,
        "extract_earnings": true
    },
    
    "analysis_settings": {
        "max_articles": 20,
        "lookback_days": 7,
        "min_keyword_matches": 2,
        "focus_areas": ["stocks", "bonds", "forex", "commodities", "macro"]
    },
    
    "report_style": {
        "primary_color": "#00ff88",
        "secondary_color": "#0088ff",
        "accent_color": "#ffaa00",
        "style": "professional",
        "font_family": "'Inter', 'Roboto', sans-serif"
    }
}